{
    "name": "workspace",
    "image": "mcr.microsoft.com/devcontainers/python:3",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "github.copilot",
                "github.copilot-chat",
                "charliermarsh.ruff",
                "ms-python.mypy-type-checker",
                "humao.rest-client",
                "mtxr.sqltools",
                "mtxr.sqltools-driver-pg"
            ]
        }
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.copilot,target=/home/node/.copilot,type=bind,consistency=cached"
    ],
    "forwardPorts": [
        5432,
        8000
    ],
    "initializeCommand": "node -e \"require('fs').mkdirSync(require('path').join(require('os').homedir(),'.copilot'),{recursive:true})\"",
    "postCreateCommand": "curl -fsSL https://gh.io/copilot-install | bash",
    "remoteUser": "vscode"
}
